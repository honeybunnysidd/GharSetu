<% layout('./layouts/boilerplate') -%>

  <div class="row">
    <div class="col-8 offset-2">
      <h3 class="container mt-4">Create New Listing:</h3>
      <form action="/listings" method="post" class="container mt-5 mb-5">
        <div class="mb-3">
          <label for="title" class="form-label">Title</label>
          <input
            type="text"
            name="title"
            class="form-control"
            required
            id="title"
            placeholder="Enter a title"
          />
        </div>

        <div class="mb-3">
          <label for="description" class="form-label">Description</label>
          <textarea
            name="description"
            class="form-control"
            required
            id="description"
            placeholder="Write the description"
          ></textarea>
        </div>

        <div class="mb-3">
          <label for="img" class="form-label">Image url</label>
          <input
            required
            type="url"
            class="form-control"
            id="img"
            name="img"
            placeholder="Enter image URL/Link"
          />
        </div>
<div class="row">
        <div class="mb-3 col-md-4">
          <label for="price" class="form-label">Price</label>
          <input
            required
            type="number"
            class="form-control"
            id="price"
            name="price"
            placeholder="Enter Price"
          />
        </div>
        <div class="mb-3 col-md-8">
          <label for="location" class="form-label">Country</label>
          <input
            type="text"
            name="country"
            class="form-control"
            required
            id="country"
            placeholder="Enter country"
          />
        </div>
      </div>
        <div class="mb-3">
          <label for="location" class="form-label">Location</label>
          <input
            type="text"
            name="location"
            class="form-control"
            required
            id="location"
            placeholder="Enter location"
          />
        </div>

        <a href="/listings" class="btn btn-danger">Back</a>
        <button type="submit" class="btn btn-success ms-3">Create</button>
      </form>
    </div>
  </div>
