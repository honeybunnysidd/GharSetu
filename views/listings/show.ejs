<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Chat</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
  </head>
  <body>
    <table border="1">
      <tr>
        <th>Title</th>
        <th>Description</th>
        <th>Price</th>
        <th>Location</th>
        <th>Country</th>
      </tr>

      <tr>
        <td><%=curListing.title %></td>
        <td><%=curListing.description %></td>
        <td>₹ <%=curListing.price.toLocaleString("en-IN") %></td>
        <td><%=curListing.location %></td>
        <td><%=curListing.country%></td>
      </tr>
    </table>

    <img src="<%= curListing.image.url %>" alt="" />
    <a href="/listings" class="btn btn-danger">Back</a>
    <form action="/listings/<%= curListing._id%>/edit" method="get">
      <button class="btn btn-primary">Edit</button>
    </form>
  </body>
</html>
