<% layout('./layouts/boilerplate') -%>

<div class="row mt-4 mb-5">
  <div class="col-8 offset-3">
    <h3>Listing Details:</h3>
    <div class="card show-card col-8">
      <img
        src="<%=curListing.image.url %>"
        class="card-img-top show-img"
        alt="img"
      />
      <div class="card-body">
        <p class="card-text">
          <b><%=curListing.title %></b><br />
          <%=curListing.description %> <br />
          $ <%=curListing.price.toLocaleString("en-IN") %> /night <br />
          <%=curListing.location %>, <%=curListing.country%>
        </p>
      </div>
    </div>

    <form action="/listings/<%= curListing._id%>?_method=DELETE" method="post" class="ms-2" >
      <button class="btn btn-danger me-3">Delete</button>
      <a href="/listings/<%= curListing._id%>/edit" class="btn btn-success"
        >Edit</a
      >
    </form>
  </div>
</div>
